{
  "name": "jugihub-hotspot",
  "private": true,
  "version": "1.0.0",
  "description": "Production-ready ISP hotspot management system for JugiHub Internet.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @jugihub/api & npm run dev --workspace @jugihub/web",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces",
    "test": "npm run test --workspaces",
    "db:generate": "npm run prisma:generate --workspace @jugihub/api",
    "db:migrate": "npm run prisma:migrate --workspace @jugihub/api",
    "docker:up": "docker compose up --build"
  },
  "engines": {
    "node": "20.x",
    "npm": ">=10.0.0"
  }
}
